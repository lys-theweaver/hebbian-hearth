# Supabase 项目地址和 service_role key（不是anon key！）
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=your_service_role_key

# Gemini API key（免费申请：aistudio.google.com -> Get API key）
GEMINI_API_KEY=your_gemini_key
# embedding模型，默认3072维。换模型必须同步改 schema.sql 里 vector() 的维度
EMBED_MODEL=gemini-embedding-001
